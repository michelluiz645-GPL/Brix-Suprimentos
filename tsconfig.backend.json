{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "dist-backend",
    "rootDir": ".",
    "strict": true,
    "noEmit": false
  },
  "include": ["backend/server.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
